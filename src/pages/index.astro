---
import '../styles/global.css';
import RotatingDot from '../components/RotatingDot';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Portfolio</title>
	</head>
	<body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
		<main class="mx-auto flex min-h-screen max-w-3xl items-center justify-center px-6">
			<div class="rounded-xl border border-slate-800 bg-slate-900/70 p-8 shadow-lg">
				<RotatingDot client:load />
				<h1 class="text-3xl font-semibold tracking-tight">Tailwind is working</h1>
				<p class="mt-3 text-slate-300">Simple starter page ready for your portfolio build.</p>
			</div>
		</main>
	</body>
</html>
